# =============================================================================
# .env.example — Variáveis de ambiente do projeto distributed-bank
# Copie este arquivo para .env e ajuste os valores para seu ambiente local.
# NUNCA commite o arquivo .env real.
# =============================================================================

# PostgreSQL
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus_secret
POSTGRES_DB=nexusbank

# Conexão da aplicação com o banco
DB_URL=jdbc:postgresql://localhost:5432/nexusbank
DB_USERNAME=nexus
DB_PASSWORD=nexus_secret

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis

# Kafka
KAFKA_SERVERS=localhost:9092

# Aplicação
SERVER_PORT=8080
